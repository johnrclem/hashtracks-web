{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run lint*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx vitest*)",
      "Bash(npx prisma studio*)",
      "Bash(npx prisma generate*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(npx prisma db push*)",
      "Bash(npx prisma migrate*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
