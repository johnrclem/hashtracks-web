"description":"Regularly scheduled trail placeholder. Details will be posted when the trail is set."}}];

const trailCalendarStartDate =
"2026-06-01";

function escapeCalendarHtml(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

document.addEventListener(
    'DOMContentLoaded',
    function() {

        const calendarEl =
            document.getElementById(
                'trailCalendar'
            );

        if (!calendarEl) {
            return;
        }

        const calendar =
            new FullCalendar.Calendar(
                calendarEl,
                {

                    initialView:
                        'dayGridMonth',

                    initialDate:
                        trailCalendarStartDate,

                    height:
                        'auto',

                    dayMaxEvents:
                        true,

                    eventDisplay:
                        'block',

                    headerToolbar: {

                        left:
                            'prev,next today',

                        center:
                            'title',

                        right:
                            'dayGridMonth,listMonth'
                    },

                    events:
                        trailCalendarEvents,

                    eventClick:
                        function(info) {
                            info.jsEvent.preventDefault();

                            const p =
                                info.event.extendedProps;

                            const detailsUrl =
                                info.event.url || '';

                            const locationText =
                                p.locationAddress || p.location || '';

                            document.getElementById(
                                'modalTitle'
                            ).textContent =
                                p.title || info.event.title;

                            document.getElementById(
                                'modalDetails'
                            ).innerHTML =
                                `
                                <p><strong>Kennel:</strong> ${escapeCalendarHtml(p.kennel)}</p>
                                <p><strong>Hares:</strong> ${escapeCalendarHtml(p.hares)}</p>
                                <p><strong>Gather:</strong> ${escapeCalendarHtml(p.gatherTime)}</p>
                                <p><strong>Start:</strong> ${escapeCalendarHtml(p.startTime)}</p>
                                <p><strong>Location:</strong> ${
                                    p.locationUrls && p.locationUrls.apple && p.locationUrls.google
                                        ? `<a class="map-link" href="${escapeCalendarHtml(p.locationUrls.google)}" data-apple-map-url="${escapeCalendarHtml(p.locationUrls.apple)}" data-google-map-url="${escapeCalendarHtml(p.locationUrls.google)}" target="_blank" rel="noopener noreferrer">${escapeCalendarHtml(locationText)}</a>`
                                        : escapeCalendarHtml(locationText)
                                }</p>
                                <p><strong>Cost:</strong> ${escapeCalendarHtml(p.cost)}</p>
                                <p>${escapeCalendarHtml(p.description)}</p>
                                ${
                                    detailsUrl
                                        ? `<p><a class="registration-button" href="${escapeCalendarHtml(detailsUrl)}">View Details</a></p>`
                                        : ''
                                }
                                `;

                            if (typeof applyMapLinkDefaults === 'function') {
                                applyMapLinkDefaults(
                                    document.getElementById('modalDetails')
                                );
                            }

                            document
                                .getElementById(
                                    'calendarModal'
                                )
                                .classList
                                .add('active');
                        }
                }
            );

        calendar.render();

        const modal =
            document.getElementById(
                'calendarModal'
            );

        document
            .getElementById(
                'calendarModalClose'
            )
            .addEventListener(
                'click',
                () =>
                    modal.classList.remove(
                        'active'
                    )
            );

        modal.addEventListener(
            'click',
            function(e) {

                if (
                    e.target === modal
                ) {

                    modal.classList.remove(
                        'active'
                    );
                }
            }
        );
    }
);

</script>


</main>

