 <tr height=22 style='mso-height-source:userset;height:16.5pt'>
  <td colspan=5 height=22 class=xl1044785 width=865 style='height:16.5pt;
  width:650pt'>If you would like to set a run contact the Trail Master.</td>
  <td class=xl654785 width=144 style='width:108pt'>&nbsp;</td>
 </tr>
 <tr height=22 style='mso-height-source:userset;height:16.5pt'>
  <td colspan=5 height=22 class=xl1064785 width=865 style='height:16.5pt;
  width:650pt'>If you've never set a run before, the Trail Master is happy to
  help - just ask</td>
  <td class=xl664785 width=144 style='width:108pt'>&nbsp;</td>
 </tr>
 <tr height=29 style='mso-height-source:userset;height:21.75pt'>
  <td colspan=5 height=29 class=xl1084785 width=865 style='height:21.75pt;
