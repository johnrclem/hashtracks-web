  target="_parent"><span style='color:blue;font-weight:400;text-decoration:
  underline;text-underline-style:single'>Contact:
  trailmaster@aucklandhussies.co.nz</span></a></td>
  <td class=xl664785 width=144 style='width:108pt'>&nbsp;</td>
 </tr>
 <tr height=22 style='mso-height-source:userset;height:16.5pt'>
