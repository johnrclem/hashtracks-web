et":9},{"entity":{"__typename":"User","__isEntity":"User","__isActor":"User","id":"100051181521698","url":"https:\/\/www.facebook.com\/HollyweirdH6","profile_url":"https:\/\/www.facebook.com\/HollyweirdH6","short_name":"HHHH Hollyweird Hash House Harriers aka: H6","work_info":null,"__module_operation_CometTextWithEntitiesRelay_textWithEntities":{"__dr":"ProfileGeminiWeakReferenceLink_user$normalization.graphql"},"__module_component_CometTextWithEntitiesRelay_textWithEntities":{"__dr":"ProfileGeminiWeakReferenceLink.react"},"work_foreign_entity_info":null,"is_verified":false,"show_promode_badge":false,"mobileUrl":"https:\/\/m.facebook.com\/HollyweirdH6\/","__isNode":"User"},"entity_is_weak_reference":false,"length":43,"offset":23}],"color_ranges":[],"text":"Event by Rich Aube and HHHH Hollyweird Hash House Harriers aka: H6"}},"send_calendar_invite":false,"should_show_calendar_invite_preview":false,"display_duration":null,"event_price_and_duration_context_row_info":null,"can_share_room_link":false,"event_kind":"PUBLIC_TYPE","content_geogating":null,"is_viewer_host":false,"event_creator":{"__typename":"User","name":"HHHH Hollyweird Hash House Harriers aka: H6","id":"100051181521698"},"created_for_group":null,"is_work_entity":false,"event_privacy_info":{"title":{"__typename":"TextWithEntities"},"icon_name":"globe-americas"},"event_hosts_that_can_view_guestlist":[{"__typename":"User","__isProfile":"User","id":"700429636","name":"Rich Aube","is_verified":false,"url":"https:\/\/www.facebook.com\/raube","__isActor":"User","__isMessagingActor":"User","can_viewer_message":false,"is_secure_thread":null,"message_capabilities2_str":null,"is_od_cutover_eligible":false,"profile_picture":{"uri":"https:\/\/scontent-lga3-3.xx.fbcdn.net\/v\/t39.30808-1\/683139370_10164195303224637_8200357898108377697_n.jpg?stp=cp0_dst-jpg_s74x74_tt6&_nc_cat=104&ccb=1-7&_nc_sid=1d2534&_nc_ohc=1Vs4unIR-X8Q7kNvwETQDYZ&_nc_oc=Adqajqf46XuCNb2r_8MQ8_qL0_zRGe-v1gowgvPpKyHG7BGWrFoF12G4awYRbCXRXuw&_nc_zt=24&_nc_ht=scontent-lga3-3.xx&_nc_gid=SZzd1bYk25_qNgBhmN-hHA&_nc_ss=70289&oh=00_Af6IWN-673ImLsUbqnxkgyFFOL6hGihi2ilpsYkVUuCLPA&oe=6A064E7D"}},{"__typename":"User","__isProfile":"User","id":"100051181521698","name":"HHHH Hollyweird Hash House Harriers aka: H6","is_verified":false,"url":"https:\/\/www.facebook.com\/HollyweirdH6","__isActor":"User","__isMessagingActor":"User","can_viewer_message":false,"is_secure_thread":null,"message_capabilities2_str":null,"is_od_cutover_eligible":false,"profile_picture":{"uri":"https:\/\/scontent-lga3-3.xx.fbcdn.net\/v\/t39.30808-1\/404938903_922225522826823_3951962098427768231_n.jpg?stp=c11.0.1058.1059a_cp0_dst-jpg_s74x74_tt6&_nc_cat=102&ccb=1-7&_nc_sid=2d3e12&_nc_ohc=e5zAEYjt5_4Q7kNvwEHYTf0&_nc_oc=AdokJIDi_jJe2zMXFVQ00qMzpSk-tkznxqzDkcol2jzzcwunrcXctKVBjWKYqfjalsM&_nc_zt=24&_nc_ht=scontent-lga3-3.xx&_nc_gid=SZzd1bYk25_qNgBhmN-hHA&_nc_ss=70289&oh=00_Af46qgOcxqgKOPxEkm0BXg8P_5C5BmE8hxNeSuU2l76HBA&oe=6A065E79"}}],"parent_event":null,"event_description":{"text":"Hollyweird Hash House Harriers HapPy Hour 4 All we can Eat Tacos \u0040 Bandoleros ~ H6 #308\n\n\ud83d\udcc5 Whenceforth: 05\/29\/26\n\ud83c\udf89\ud83c\udf7b \"Friday is a Hashing Day!\" \ud83d\udc07\ud83c\udfc3\u200d\u2642\ufe0f\ud83c\udf7a\n\n  .oooO  Oooo.\n   (     )   (     )\n    \\   (     )    \/\n     \\_)     (_\/\n\nHare: \ud83d\udc30\u2728 Senorita Pink Taco and\/or \u00bf Going or Cumin ?\n\nLaunchpad: \ud83d\udccd Bandoleros\n208 SW 2nd St, Fort Lauderdale, FL, United States, Florida 33301\n\u27a1\ufe0f e'rections: GPS it, then look \ud83d\udc40 just around a park for \ud83c\udf7a-drinking + \ud83d\ude31 screaming Hashers = our usual spot\nPre-lube: \ud83c\udf7b 5ish for \ud83d\ude99 tailgating\nHare Away: \u23f0 6:30 \ud83c\udd7f\ufe0fee M\n\ud83c\udfc1 A to A Trail\n\ud83c\udf9f\ufe0f Free Hash + B\u2714\ufe0f + Snacks\n\ud83c\udf7b Bring Pre\/Post Lube & \ud83d\udcb5 on trail for  BC\n\ud83d\ude4c Your welcomed 2 get the Hare a \ud83c\udf7a 4 all her hard work + \ud83c\udf7b\n\u2b50 Theme: \ud83c\udf79\ud83c\udfc3\ud83c\udf79\ud83d\udd01 drink, run, tacos, karaokee drink, dance, repeat \ud83c\udf89\n\nOn-After: $20 all you can eat Tacos& karaokee\n\nRU?  \ud83c\udf7b.\ud83d\udc07.\ud83e\uddae.\ud83c\udfc3.\ud83d\udca8 \ud83c\udf2e\n\nON-ON! \ud83d\udd14.\ud83d\udc63.\ud83c\udf7a\n\nhttps:\/\/www.facebook.com\/share\/1B3GaHZCnV\/\n\u300b\n\u300b\u300b\n\ud83c\udfa4 Get Ready to Sing Your Heart Out at Karaoke Fridays!\nLooking for the ultimate Friday night plans? Grab your friends and head over to Bandoleros Tacos in Oakland Park for a night of high-energy singing, delicious eats, and refreshing drinks!\n\nWhether you\u2019re a closet superstar or just want to cheer on your friends, Joseph is hosting the party and keeping the vibes high all night long.\n\n\ud83c\udf2e The Main Event: All-You-Can-Eat Tacos!\nFor just $19.99, feast on unlimited tacos! Choose your favorites or try them all:\n\nChicken\nGringo Beef\nCarnitas\nVeggie Tacos\n\n\ud83c\udf79 Drink Specials to Loosen Those Vocal Chords\n$5 Tequila Shots \ud83e\udd43\n$6 Classic Margs\u2019 \ud83c\udf78\n\nKaraoke Starts: 7:00 PM\n\nWhere: Bandoleros Tacos - Oakland Park\n\nAddress: 3200 NE 12th Avenue, Oakland Park, FL 33334\n\nJoin us and sing your hearts out! It\u2019s going to be a fiesta to remember.","delight_ranges":[],"image_ranges":[],"inline_style_ranges":[],"aggregated_ranges":[],"ranges":[{"entity":{"__typename":"Event","__isEntity":"Event","__isActor":"Event","id":"1481362937047925","url":"https:\/\/www.facebook.com\/events\/1481362937047925\/","profile_url":"https:\/\/www.facebook.com\/events\/1481362937047925\/","mobileUrl":"https:\/\/m.facebook.com\/events\/1481362937047925\/","__isNode":"Event"},"entity_is_weak_reference":false,"length":42,"offset":827}],"color_ranges":[]},"creation_story":{"click_tracking_linkshim_cb":"AUBCvLQc9g8CCENzn_GXtddYAzoX5ga7bq1wQak9CELW_xPakMpSuHbQVrIYNbq-a7Bv-9_nd0vfshj7c2KpPr7snqzmZb72y_34QDdyet0qM24kCZRIZN2NVfBruHZ33H0eToMO